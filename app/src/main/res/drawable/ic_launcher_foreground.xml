<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── 玻璃圆 外发光（较大，极淡） ── -->
    <path android:fillColor="#1E7766EE"
          android:pathData="M17,54 a37,37 0 1,0 74,0 a37,37 0 1,0 -74,0"/>

    <!-- ── 玻璃圆 外发光（稍小，略深） ── -->
    <path android:fillColor="#154455CC"
          android:pathData="M20,54 a34,34 0 1,0 68,0 a34,34 0 1,0 -68,0"/>

    <!-- ── 玻璃圆 主体径向渐变 ── -->
    <path android:pathData="M24,54 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="45"
                android:centerY="43"
                android:gradientRadius="40"
                android:startColor="#30FFFFFF"
                android:endColor="#0A060818"/>
        </aapt:attr>
    </path>

    <!-- ── 顶部镜面高光（上半弓形区域） ── -->
    <path android:pathData="M24,54 a30,30 0 0,1 60,0 L84,54 L24,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="24"
                android:endX="54"   android:endY="54"
                android:startColor="#A6FFFFFF"
                android:endColor="#00FFFFFF"/>
        </aapt:attr>
    </path>

    <!-- ── 左上对角散射光斑 ── -->
    <path android:pathData="M24,54 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="24" android:startY="24"
                android:endX="84"   android:endY="84"
                android:startColor="#47FFFFFF"
                android:endColor="#00FFFFFF"/>
        </aapt:attr>
    </path>

    <!-- ── 玻璃圆 主边框 ── -->
    <path android:fillColor="#00000000"
          android:strokeColor="#99FFFFFF"
          android:strokeWidth="0.9"
          android:pathData="M24,54 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"/>

    <!-- ── 顶部强化亮边（折射感） ── -->
    <path android:fillColor="#00000000"
          android:strokeColor="#CCFFFFFF"
          android:strokeWidth="0.7"
          android:pathData="M30.4,36.8 a30,30 0 0,1 47.2,0"/>

    <!-- ── 播放键 外发光（稍大，半透明蓝白） ── -->
    <path android:fillColor="#2FAABBFF"
          android:pathData="M46,42 L46,66 L70,54 Z"/>

    <!-- ── 播放键 主体 ── -->
    <path android:pathData="M48,44 L48,64 L68,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="48" android:startY="44"
                android:endX="68"   android:endY="64"
                android:startColor="#FFFFFFFF"
                android:endColor="#DFB8CCFF"/>
        </aapt:attr>
    </path>

</vector>
